<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= namaToko %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        /* Efek Tulisan Neon Glow untuk Nama Toko */
        .neon-text {
            color: #fff;
            text-shadow: 
                0 0 5px #00f0ff,
                0 0 10px #00f0ff,
                0 0 20px #00f0ff,
                0 0 40px #0044ff;
        }
    </style>
</head>
<body class="bg-[#0b0f19] text-white font-sans min-h-screen p-6 relative">

    <header class="flex justify-between items-center bg-[#111827] p-4 rounded-lg mb-8 shadow-md border border-gray-800">
        <div class="flex items-center space-x-2 text-2xl font-black tracking-wider">
            <span>🎸</span>
            <span class="neon-text font-serif italic"><%= namaToko %></span>
        </div>
        <div class="w-1/3">
            <input type="text" id="inputCari" oninput="filterGitar()" placeholder="Cari gitar..." class="w-full bg-[#1f2937] text-gray-300 px-4 py-2 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 text-sm border border-gray-700">
        </div>
        <button onclick="bukaModalTambah()" class="bg-emerald-600 hover:bg-emerald-700 transition px-4 py-2 rounded-md text-sm font-semibold flex items-center space-x-1">
            <span>+</span> <span>Tambah</span>
        </button>
    </header>

    <main class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-4 gap-6">
        <aside class="bg-[#111827] p-4 rounded-lg h-fit border border-gray-800 shadow-sm">
            <h3 class="text-gray-400 text-sm font-semibold mb-3">Kategori</h3>
            <div class="flex flex-col space-y-2" id="kategoriContainer">
                <button onclick="gantiKategori('Semua', this)" class="btn-kategori bg-blue-600 text-left px-4 py-2 rounded text-sm font-medium transition">Semua</button>
                <button onclick="gantiKategori('Akustik', this)" class="btn-kategori bg-[#1f2937] text-left px-4 py-2 rounded text-sm hover:bg-gray-700 transition">Akustik</button>
                <button onclick="gantiKategori('Listrik', this)" class="btn-kategori bg-[#1f2937] text-left px-4 py-2 rounded text-sm hover:bg-gray-700 transition">Listrik</button>
                <button onclick="gantiKategori('Klasik', this)" class="btn-kategori bg-[#1f2937] text-left px-4 py-2 rounded text-sm hover:bg-gray-700 transition">Klasik</button>
            </div>
        </aside>

        <section id="guitarContainer" class="md:col-span-3 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            <% guitars.forEach(gitar => { %>
                <div class="card-gitar bg-[#111827] p-4 rounded-lg relative flex flex-col justify-between shadow-lg border border-gray-800 hover:border-gray-700 transition" 
                     data-name="<%= gitar.name.toLowerCase() %>" 
                     data-category="<%= gitar.category %>"
                     data-terlaris="<%= gitar.popular || gitar.terlaris ? 'true' : 'false' %>">
                    
                    <% if (gitar.popular || gitar.terlaris) { %>
                        <span class="absolute top-2 right-2 bg-amber-500 text-xs text-black font-bold px-2 py-0.5 rounded-full shadow-sm">🔥 Terlaris</span>
                    <% } %>
                    <div>
                        <span class="text-xs text-gray-500 block mb-1">Gitar <%= gitar.category %></span>
                        <h4 class="text-lg font-bold mb-2 tracking-wide text-gray-200"><%= gitar.name %></h4>
                        <p class="text-emerald-400 font-extrabold mb-2 text-base">Rp <%= typeof gitar.price === 'number' ? gitar.price.toLocaleString('id-ID') : gitar.price %></p>
                        <p class="text-gray-400 text-xs line-clamp-2 mb-4 h-8"><%= gitar.description %></p>
                    </div>
                    <div class="flex space-x-2 text-xs pt-2 border-t border-gray-800">
                        <button onclick="detailGitar('<%= gitar.id %>')" class="bg-slate-700 hover:bg-slate-600 px-3 py-1.5 rounded font-medium transition">Detail</button>
                        <button onclick="bukaModalEdit('<%= gitar.id %>')" class="bg-amber-500 hover:bg-amber-600 px-3 py-1.5 rounded font-medium text-black transition">Edit</button>
                        <button onclick="konfirmasiHapus('<%= gitar.id %>')" class="bg-rose-600 hover:bg-rose-700 px-3 py-1.5 rounded font-medium transition">Hapus</button>
                    </div>
                </div>
            <% }) %>
        </section>
    </main>

    <section class="max-w-7xl mx-auto mt-12 grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-[#111827] p-6 rounded-lg text-center shadow-lg border border-gray-800">
            <h2 id="statTotalProduk" class="text-4xl font-extrabold text-blue-400 mb-1">0</h2>
            <p class="text-gray-400 text-xs tracking-wider uppercase">Total Produk</p>
        </div>
        <div class="bg-[#111827] p-6 rounded-lg text-center shadow-lg border border-gray-800">
            <h2 id="statTotalTerjual" class="text-4xl font-extrabold text-purple-400 mb-1">0</h2>
            <p class="text-gray-400 text-xs tracking-wider uppercase">Total Terjual</p>
        </div>
    </section>

    <div id="detailModal" class="hidden fixed inset-0 bg-black/70 backdrop-blur-sm flex justify-center items-center p-4 z-50">
        <div class="bg-[#111827] w-full max-w-md p-6 rounded-xl border border-gray-800 shadow-2xl">
            <div class="flex justify-between items-center pb-3 border-b border-gray-800 mb-4">
                <h3 class="text-xl font-bold text-gray-200 flex items-center space-x-2">
                    <span>🎸</span> <span>Detail Gitar</span>
                </h3>
                <button onclick="tutupModal('detailModal')" class="text-gray-400 hover:text-white text-xl">&times;</button>
            </div>
            <div class="space-y-4 text-sm">
                <div>
                    <span class="text-xs text-gray-500 block">Nama Produk</span>
                    <p id="modalName" class="text-base font-bold text-gray-100"></p>
                </div>
                <div>
                    <span class="text-xs text-gray-500 block">Kategori</span>
                    <p id="modalCategory" class="inline-block bg-[#1f2937] px-2.5 py-1 rounded text-xs text-blue-400 font-medium mt-1"></p>
                </div>
                <div>
                    <span class="text-xs text-gray-500 block">Harga</span>
                    <p id="modalPrice" class="text-lg font-black text-emerald-400 mt-0.5"></p>
                </div>
                <div>
                    <span class="text-xs text-gray-500 block">Deskripsi Lengkap</span>
                    <p id="modalDescription" class="text-gray-400 leading-relaxed mt-1 bg-[#0b0f19] p-3 rounded border border-gray-800/50"></p>
                </div>
            </div>
            <div class="mt-6 flex justify-end">
                <button onclick="tutupModal('detailModal')" class="bg-blue-600 hover:bg-blue-700 transition px-5 py-2 rounded-md text-sm font-semibold shadow-md">Tutup</button>
            </div>
        </div>
    </div>

    <div id="formModal" class="hidden fixed inset-0 bg-black/70 backdrop-blur-sm flex justify-center items-center p-4 z-50">
        <div class="bg-[#111827] w-full max-w-md p-6 rounded-xl border border-gray-800 shadow-2xl">
            <div class="flex justify-between items-center pb-3 border-b border-gray-800 mb-4">
                <h3 id="formModalTitle" class="text-xl font-bold text-gray-200">Form Gitar</h3>
                <button onclick="tutupModal('formModal')" class="text-gray-400 hover:text-white text-xl">&times;</button>
            </div>
            <form id="guitarForm" onsubmit="simpanForm(event)" class="space-y-4 text-sm">
                <input type="hidden" id="formId">
                <div>
                    <label class="block text-xs text-gray-400 mb-1">Nama Gitar</label>
                    <input type="text" id="formName" required class="w-full bg-[#1f2937] border border-gray-700 rounded p-2.5 text-gray-200 focus:outline-none focus:ring-2 focus:ring-blue-500">
                </div>
                <div>
                    <label class="block text-xs text-gray-400 mb-1">Kategori</label>
                    <select id="formCategory" class="w-full bg-[#1f2937] border border-gray-700 rounded p-2.5 text-gray-200 focus:outline-none focus:ring-2 focus:ring-blue-500">
                        <option value="Akustik">Akustik</option>
                        <option value="Listrik">Listrik</option>
                        <option value="Klasik">Klasik</option>
                    </select>
                </div>
                <div>
                    <label class="block text-xs text-gray-400 mb-1">Harga (Contoh: 1.500.000)</label>
                    <input type="text" id="formPrice" required class="w-full bg-[#1f2937] border border-gray-700 rounded p-2.5 text-gray-200 focus:outline-none focus:ring-2 focus:ring-blue-500">
                </div>
                <div>
                    <label class="block text-xs text-gray-400 mb-1">Deskripsi</label>
                    <textarea id="formDescription" rows="3" required class="w-full bg-[#1f2937] border border-gray-700 rounded p-2.5 text-gray-200 focus:outline-none focus:ring-2 focus:ring-blue-500"></textarea>
                </div>
                <div class="flex justify-end space-x-2 pt-2">
                    <button type="button" onclick="tutupModal('formModal')" class="bg-gray-700 hover:bg-gray-600 px-4 py-2 rounded text-sm font-medium">Batal</button>
                    <button type="submit" class="bg-blue-600 hover:bg-blue-700 px-4 py-2 rounded text-sm font-medium shadow-md">Simpan Data</button>
                </div>
            </form>
        </div>
    </div>

    <div id="deleteModal" class="hidden fixed inset-0 bg-black/70 backdrop-blur-sm flex justify-center items-center p-4 z-50">
        <div class="bg-[#111827] w-full max-w-sm p-6 rounded-xl border border-gray-800 shadow-2xl text-center">
            <div class="text-rose-500 text-4xl mb-2">⚠️</div>
            <h3 class="text-lg font-bold text-gray-200 mb-2">Hapus Produk?</h3>
            <p class="text-gray-400 text-sm mb-6">Tindakan ini tidak bisa dibatalkan. Kamu yakin ingin menghapus gitar ini dari sistem?</p>
            <input type="hidden" id="deleteId">
            <div class="flex justify-center space-x-3">
                <button onclick="tutupModal('deleteModal')" class="bg-gray-700 hover:bg-gray-600 px-4 py-2 rounded text-sm font-medium">Batal</button>
                <button onclick="eksekusiHapus()" class="bg-rose-600 hover:bg-rose-700 px-4 py-2 rounded text-sm font-medium shadow-md">Ya, Hapus</button>
            </div>
        </div>
    </div>

    <script>
      const API_URL = 'http://127.0.0.1:5000/api/guitars';
      let kategoriAktif = 'Semua';

      // RUN OTOMATIS SAAT HALAMAN DIBUKA (MENGHITUNG PRODUK)
      document.addEventListener("DOMContentLoaded", () => {
          hitungStatistik();
      });

      function tutupModal(id) {
        document.getElementById(id).classList.add('hidden');
      }

      // ==========================================
      // LOGIKA FILTER KATEGORI & PENCARIAN (SEARCH)
      // ==========================================
      function gantiKategori(kategori, elemen) {
          kategoriAktif = kategori;
          
          // Mengubah warna tombol kategori aktif di sidebar
          document.querySelectorAll('.btn-kategori').forEach(btn => {
              btn.classList.remove('bg-blue-600', 'font-medium');
              btn.classList.add('bg-[#1f2937]');
          });
          elemen.classList.remove('bg-[#1f2937]');
          elemen.classList.add('bg-blue-600', 'font-medium');

          filterGitar();
      }

      function filterGitar() {
          const kataKunci = document.getElementById('inputCari').value.toLowerCase();
          const semuaKartu = document.querySelectorAll('.card-gitar');

          semuaKartu.forEach(card => {
              const namaGitar = card.getAttribute('data-name');
              const kategoriGitar = card.getAttribute('data-category');

              // Periksa kecocokan kategori dan kata kunci search
              const cocokKategori = (kategoriAktif === 'Semua' || kategoriGitar === kategoriAktif);
              const cocokSearch = namaGitar.includes(kataKunci);

              if (cocokKategori && cocokSearch) {
                  card.classList.remove('hidden');
              } else {
                  card.classList.add('hidden');
              }
          });
      }

      // ==========================================
      // LOGIKA MENGHITUNG STATISTIK SECARA DINAMIS
      // ==========================================
      function hitungStatistik() {
          const semuaKartu = document.querySelectorAll('.card-gitar');
          const totalProduk = semuaKartu.length;
          
          let totalTerlaris = 0;
          semuaKartu.forEach(card => {
              if (card.getAttribute('data-terlaris') === 'true') {
                  totalTerlaris++;
              }
          });

          // Rumus estimasi penjualan: jumlah gitar terlaris dikali angka dasar (misal 35) + sisa produk lain dikali 12
          const estimasiTerjual = (totalTerlaris * 35) + ((totalProduk - totalTerlaris) * 12);

          document.getElementById('statTotalProduk').innerText = totalProduk;
          document.getElementById('statTotalTerjual').innerText = totalProduk > 0 ? estimasiTerjual : 0;
      }

      // ==========================================
      // FITUR CRUD DATABASE
      // ==========================================
      async function detailGitar(id) {
        try {
          const res = await fetch(`${API_URL}/${id}`);
          const gitar = await res.json();
          document.getElementById('modalName').innerText = gitar.name;
          document.getElementById('modalCategory').innerText = `Gitar ${gitar.category}`;
          document.getElementById('modalPrice').innerText = `Rp ${gitar.price}`;
          document.getElementById('modalDescription').innerText = gitar.description;
          document.getElementById('detailModal').classList.remove('hidden');
        } catch (err) {
          alert('Gagal mengambil data detail.');
        }
      }

      function bukaModalTambah() {
        document.getElementById('formModalTitle').innerText = "🎸 Tambah Gitar Baru";
        document.getElementById('formId').value = "";
        document.getElementById('guitarForm').reset();
        document.getElementById('formModal').classList.remove('hidden');
      }

      async function bukaModalEdit(id) {
        try {
          const res = await fetch(`${API_URL}/${id}`);
          const gitar = await res.json();
          
          document.getElementById('formModalTitle').innerText = "✏️ Edit Data Gitar";
          document.getElementById('formId').value = gitar.id;
          document.getElementById('formName').value = gitar.name;
          document.getElementById('formCategory').value = gitar.category;
          document.getElementById('formPrice').value = gitar.price;
          document.getElementById('formDescription').value = gitar.description;
          
          document.getElementById('formModal').classList.remove('hidden');
        } catch (err) {
          alert('Gagal memuat data lama.');
        }
      }

      async function simpanForm(e) {
        e.preventDefault();
        const id = document.getElementById('formId').value;
        const name = document.getElementById('formName').value;
        const category = document.getElementById('formCategory').value;
        const price = document.getElementById('formPrice').value;
        const description = document.getElementById('formDescription').value;

        const bodyData = JSON.stringify({ name, category, price, description, popular: false });
        const url = id ? `${API_URL}/${id}` : API_URL;
        const method = id ? 'PUT' : 'POST';

        try {
          const res = await fetch(url, {
            method: method,
            headers: { 'Content-Type': 'application/json' },
            body: bodyData
          });
          if (res.ok) {
            tutupModal('formModal');
            window.location.reload();
          }
        } catch (err) {
          alert('Terjadi kesalahan jaringan.');
        }
      }

      function konfirmasiHapus(id) {
        document.getElementById('deleteId').value = id;
        document.getElementById('deleteModal').classList.remove('hidden');
      }

      async function eksekusiHapus() {
        const id = document.getElementById('deleteId').value;
        try {
          const res = await fetch(`${API_URL}/${id}`, { method: 'DELETE' });
          if (res.ok) {
            tutupModal('deleteModal');
            window.location.reload();
          }
        } catch (err) {
          alert('Gagal menghapus data.');
        }
      }
    </script>
</body>
</html>